# ==============================================================================
# TFG Medio Ambiente UA — Variables de entorno
# ==============================================================================
# COPIA este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env a Git.
# ==============================================================================

# ─── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=EcoAlerta
APP_PORT=5000

# ─── Base de datos PostgreSQL + PostGIS ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecoalerta_dev
DB_USER=ecoalerta
DB_PASSWORD=tu_password_segura_aqui
DB_SSL=false

# ─── JWT (Autenticación) ─────────────────────────────────────────────────────
JWT_SECRET=cambia_este_secreto_en_produccion
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Frontend ─────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000/api/v1
REACT_APP_MAP_DEFAULT_LAT=38.3452
REACT_APP_MAP_DEFAULT_LNG=-0.4815
REACT_APP_MAP_DEFAULT_ZOOM=13

# ─── Almacenamiento de imágenes ───────────────────────────────────────────────
# Opción 1: Firebase Storage
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_API_KEY=

# Opción 2: Almacenamiento local (desarrollo)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Notificaciones (opcional, fase avanzada) ─────────────────────────────────
# FCM_SERVER_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Cloudflare Turnstile (Sprint 6 — RF-SEC-01..03) ─────────────────────────
# Test keys: always pass in development. Use real keys in production.
# See: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
REACT_APP_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# ─── 2FA TOTP (Sprint 6 — RF-SEC-04..09) ─────────────────────────────────────
# Clave de cifrado para secretos TOTP (32 bytes, base64).
# Generar con: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# CRÍTICO: si pierdes esta clave, pierdes acceso a todos los 2FA de usuarios.
TOTP_ENCRYPTION_KEY=generar_con_openssl_rand_base64_32
