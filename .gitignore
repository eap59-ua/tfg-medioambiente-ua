# ==============================================================================
# TFG Medio Ambiente UA — .gitignore
# ==============================================================================

# ─── Dependencias ─────────────────────────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock

# ─── Variables de entorno (NUNCA subir a Git) ─────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Build y distribución ─────────────────────────────────────────────────────
dist/
build/
out/
.next/
coverage/

# ─── Docker ───────────────────────────────────────────────────────────────────
# No ignorar docker-compose*.yml ni Dockerfiles (son parte del proyecto)
# Pero sí los volúmenes locales de datos
docker-data/
pgdata/

# ─── IDE y editores ──────────────────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── Documentación temporal ───────────────────────────────────────────────────
docs/entrega/*.zip
docs/memoria/**/*.pdf
!docs/memoria/plantillas/*.pdf
*.tmp
~$*.docx
~$*.doc
